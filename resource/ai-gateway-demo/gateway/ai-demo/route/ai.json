{
  "route_name": "ai",
  "rules": [
    {
      "matches": [
        {
          "path": {
            "kind": "Prefix",
            "value": "/v1/"
          }
        }
      ],
      "plugins": [
        {
          "code": "wasm",
          "kind": "named",
          "name": "ai-gateway-queue"
        }
      ],
      "backends": [
        {
          "host": {
            "kind": "Host",
            "host": "127.0.0.1"
          },
          "port": 9000,
          "weight": 1
        }
      ]
    }
  ],
  "priority": 0
}
