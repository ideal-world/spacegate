{
  "route_name": "demo",
  "rules": [
    {
      "matches": [
        {
          "path": {
            "kind": "Prefix",
            "value": "/"
          }
        }
      ],
      "plugins": [
        {
          "code": "wasm",
          "kind": "named",
          "name": "hai-mix"
        }
      ],
      "backends": [
        {
          "host": {
            "kind": "Host",
            "host": "127.0.0.1"
          },
          "port": 18099,
          "weight": 1
        }
      ]
    }
  ],
  "priority": 0
}
